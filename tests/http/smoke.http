# Harbor integration: smoke battery.
#
# Surfaces every shape-of-response the mock exposes for healthy paths:
# health probe, model list, basic non-streaming chat. Streaming, error
# branches, and header propagation live in their thematic siblings
# (streaming.http, errors.http, headers.http) so each file stays narrow
# enough to read at a glance.
#
# Vars are inlined here rather than imported from a separate variables.http —
# httpyac runs every .http in the staging dir, and a vars-only file shows
# up as "0 requests processed" noise in the suite output.

@mock_openai_port = 29350
@base_url = http://localhost:{{mock_openai_port}}
@mock_model = mock-model

### Health endpoint is reachable
# @name health-check
GET {{base_url}}/health

?? status == 200
?? body status == ok
?? body service == mock-openai
?? header content-type == application/json

###

### GET /v1/models returns model list
# @name models-list
GET {{base_url}}/v1/models

?? status == 200
?? body object == list
?? js response.parsedBody.data[0].id == mock-model
?? js response.parsedBody.data[0].owned_by == mock

###

### POST /v1/chat/completions returns valid response
# @name chat-completions
POST {{base_url}}/v1/chat/completions
Content-Type: application/json

{
  "model": "{{mock_model}}",
  "messages": [{"role": "user", "content": "Hello"}]
}

?? status == 200
?? body object == chat.completion
?? js response.parsedBody.choices[0].message.role == assistant
?? js response.parsedBody.choices[0].message.content != null
?? js response.parsedBody.choices[0].finish_reason == stop
?? js response.parsedBody.usage.total_tokens > 0

###
