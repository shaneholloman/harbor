# Harbor integration: error-path battery.
#
# OpenAI-style proxies must propagate the canonical `{"error": {...}}`
# envelope with `code`, `message`, and `type` so SDKs can branch on the
# error class. Anything that flattens or rewrites that shape will break
# downstream clients without crashing the request, so the regression is
# silent unless explicitly asserted.

@mock_openai_port = 29350
@base_url = http://localhost:{{mock_openai_port}}
@mock_model = mock-model

### Unknown model returns 404 with model_not_found
# @name unknown-model
POST {{base_url}}/v1/chat/completions
Content-Type: application/json

{
  "model": "no-such-model",
  "messages": [{"role": "user", "content": "hi"}]
}

?? status == 404
?? body error.code == model_not_found
?? body error.type == invalid_request_error
?? js response.parsedBody.error.message != null

###

### Missing messages returns 400
# @name missing-messages
POST {{base_url}}/v1/chat/completions
Content-Type: application/json

{
  "model": "{{mock_model}}"
}

?? status == 400
?? body error.code == missing_messages
?? body error.type == invalid_request_error

###

### Empty messages array returns 400
# @name empty-messages
POST {{base_url}}/v1/chat/completions
Content-Type: application/json

{
  "model": "{{mock_model}}",
  "messages": []
}

?? status == 400
?? body error.code == missing_messages

###

### Malformed JSON returns 400 with invalid_json
# @name malformed-json
POST {{base_url}}/v1/chat/completions
Content-Type: application/json

{not valid json

?? status == 400
?? body error.code == invalid_json

###

### Unknown route returns 404
# @name unknown-route
GET {{base_url}}/v1/no/such/path

?? status == 404
?? body error.code == not_found
?? js response.parsedBody.error.message != null

###
